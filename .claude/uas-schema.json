{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UnifiedArtifactStructure",
  "description": "UAS v1 — Standard schema for all Claude-generated architecture and business artifacts. ID formats are defined in artifact-registry.json and enforced here via allOf conditionals.",
  "type": "object",
  "required": ["id", "artifact_type", "title", "version", "purpose", "inputs", "metadata"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique artifact identifier. See artifact-registry.json for the exact format per artifact_type.",
      "examples": [
        "BC", "BMC", "RISKS", "FURPS", "KPI", "GLOSSARY", "MILESTONES",
        "DM", "ERD",
        "ADR001", "ADR002",
        "UC001", "UC001-SSD", "UC001-SD", "UC001-OC",
        "UC001-DCD", "UC001-DM", "UC001-ERD"
      ]
    },
    "artifact_type": {
      "type": "string",
      "description": "Artifact type code matching the artifact_type field in artifact-registry.json.",
      "enum": [
        "BC",
        "BMC",
        "RISKS",
        "FURPS",
        "KPI",
        "GLOSSARY",
        "MILESTONES",
        "DOMAIN_MODEL",
        "ERD",
        "ADR",
        "UC_SPEC",
        "UC_SSD",
        "UC_SD",
        "UC_OC",
        "UC_DCD",
        "UC_DOMAIN_MODEL_VIEW",
        "UC_ERD_VIEW"
      ]
    },
    "title": {
      "type": "string",
      "description": "Human-readable artifact title."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d{3}$",
      "description": "Incremental 3-digit version number, zero-padded. Starts at 001 for new artifacts.",
      "examples": ["001", "002", "010"]
    },
    "purpose": {
      "type": "string",
      "description": "One or two sentences describing what this artifact achieves and why it exists."
    },
    "inputs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Explicit list of inputs (documents, decisions, assumptions) used to derive this artifact.",
      "minItems": 1
    },
    "metadata": {
      "type": "object",
      "required": ["domain"],
      "properties": {
        "domain": {
          "type": "string",
          "description": "Business or technical domain this artifact belongs to."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Searchable tags, prefixed with # (e.g. #ecommerce, #ordering)."
        },
        "author": {
          "type": "string",
          "description": "Creator of this artifact version."
        },
        "created": {
          "type": "string",
          "format": "date",
          "description": "ISO 8601 creation date (YYYY-MM-DD)."
        },
        "traceability": {
          "type": "object",
          "description": "Links to related artifacts. Use IDs from artifact-registry.json.",
          "properties": {
            "relates_to": {
              "type": "array",
              "items": { "type": "string" },
              "description": "IDs of artifacts this artifact depends on or relates to."
            },
            "supersedes": {
              "type": "array",
              "items": { "type": "string" },
              "description": "IDs of artifacts this version replaces."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "content_snapshot": {
      "type": "object",
      "description": "Optional machine-readable snapshot of key content fields for indexing and CI validation."
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "artifact_type": { "const": "ADR" } } },
      "then": { "properties": { "id": { "pattern": "^ADR\\d{3}$" } } }
    },
    {
      "if": { "properties": { "artifact_type": { "const": "DOMAIN_MODEL" } } },
      "then": { "properties": { "id": { "pattern": "^DM$" } } }
    },
    {
      "if": { "properties": { "artifact_type": { "const": "ERD" } } },
      "then": { "properties": { "id": { "pattern": "^ERD$" } } }
    },
    {
      "if": { "properties": { "artifact_type": { "const": "UC_SPEC" } } },
      "then": { "properties": { "id": { "pattern": "^UC\\d{3}$" } } }
    },
    {
      "if": { "properties": { "artifact_type": { "const": "UC_SSD" } } },
      "then": { "properties": { "id": { "pattern": "^UC\\d{3}-SSD$" } } }
    },
    {
      "if": { "properties": { "artifact_type": { "const": "UC_SD" } } },
      "then": { "properties": { "id": { "pattern": "^UC\\d{3}-SD$" } } }
    },
    {
      "if": { "properties": { "artifact_type": { "const": "UC_OC" } } },
      "then": { "properties": { "id": { "pattern": "^UC\\d{3}-OC$" } } }
    },
    {
      "if": { "properties": { "artifact_type": { "const": "UC_DCD" } } },
      "then": { "properties": { "id": { "pattern": "^UC\\d{3}-DCD$" } } }
    },
    {
      "if": { "properties": { "artifact_type": { "const": "UC_DOMAIN_MODEL_VIEW" } } },
      "then": { "properties": { "id": { "pattern": "^UC\\d{3}-DM$" } } }
    },
    {
      "if": { "properties": { "artifact_type": { "const": "UC_ERD_VIEW" } } },
      "then": { "properties": { "id": { "pattern": "^UC\\d{3}-ERD$" } } }
    }
  ]
}
